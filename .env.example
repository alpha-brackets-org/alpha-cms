# Database Configuration
DATABASE_URL=mongodb://127.0.0.1:27017/alpha-hub

# ImageKit Credentials (Media Library)
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=your_public_key
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
IMAGEKIT_PRIVATE_KEY=your_private_key

# Authentication & Security
# Generate a secure secret: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_at_least_32_chars
ENCRYPTION_KEY=your_encryption_key_exactly_32_chars

# System URLs
NEXT_PUBLIC_HUB_URL=http://localhost:3001

# SMTP Configuration (Mailtrap/SendGrid)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_user
MAIL_PASS=your_pass
MAIL_FROM="Your Name" <your@email.com>

# Newsletter & Background Workers (BullMQ)
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Monitoring Dashboard
MONITOR_PORT=3002
